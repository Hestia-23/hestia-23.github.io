---
const pathname = Astro.url.pathname;

const isActive = (slug: string): boolean => {
  if (slug === 'home') return pathname === '/' || pathname === '';
  return pathname.startsWith(`/${slug}`);
};

const links = [
  { slug: 'home', href: '/', label: 'Home' },
  { slug: 'about', href: '/about/', label: 'About' },
  { slug: 'projects', href: '/projects/', label: 'Projects' },
  { slug: 'contact', href: '/contact/', label: 'Contact' },
];
---

<nav class="nav">
  <a href="/" class="nav-mark">Alethia</a>
  <div class="nav-links">
    {links.map((l) => (
      <a
        href={l.href}
        class:list={['nav-link', { active: isActive(l.slug) }]}
      >{l.label}</a>
    ))}
  </div>
</nav>
