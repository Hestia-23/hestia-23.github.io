      <rect fill="var(--ember-wash)" x="63" y="16" width="1" height="1"/>
      <rect fill="var(--ember-wash)" x="56" y="17" width="1" height="1"/>
      <rect fill="var(--ember-wash)" x="64" y="17" width="1" height="1"/>
      <rect fill="var(--ember-wash)" x="56" y="18" width="1" height="1"/>
      <rect fill="var(--ember-wash)" x="64" y="18" width="1" height="1"/>
      <rect fill="var(--ember-wash)" x="55" y="19" width="1" height="1"/>
      <rect fill="var(--ember-wash)" x="65" y="19" width="1" height="1"/>
      <rect fill="var(--ember-wash)" x="55" y="20" width="1" height="1"/>
      <rect fill="var(--ember-wash)" x="65" y="20" width="1" height="1"/>
      <rect fill="var(--ember-wash)" x="56" y="21" width="1" height="1"/>
      <rect fill="var(--ember-wash)" x="64" y="21" width="1" height="1"/>
      <rect fill="var(--ember-wash)" x="56" y="22" width="1" height="1"/>
      <rect fill="var(--ember-wash)" x="64" y="22" width="1" height="1"/>
      <rect fill="var(--ember-wash)" x="57" y="23" width="1" height="1"/>
      <rect fill="var(--ember-wash)" x="63" y="23" width="1" height="1"/>
      <rect fill="var(--ember-wash)" x="57" y="24" width="1" height="1"/>
      <rect fill="var(--ember-wash)" x="63" y="24" width="1" height="1"/>
      <rect fill="var(--ember)" x="60" y="14" width="1" height="1"/>
      <rect fill="var(--ember)" x="59" y="15" width="3" height="1"/>
      <rect fill="var(--ember)" x="63" y="15" width="1" height="1"/>
      <rect fill="var(--ember)" x="58" y="16" width="5" height="1"/>
      <rect fill="var(--ember)" x="57" y="17" width="7" height="1"/>
      <rect fill="var(--ember)" x="57" y="18" width="7" height="1"/>
      <rect fill="var(--ember)" x="56" y="19" width="9" height="1"/>
      <rect fill="var(--ember)" x="56" y="20" width="9" height="1"/>
      <rect fill="var(--ember)" x="57" y="21" width="7" height="1"/>
      <rect fill="var(--ember)" x="57" y="22" width="7" height="1"/>
      <rect fill="var(--ember)" x="58" y="23" width="5" height="1"/>
      <rect fill="var(--ember)" x="58" y="24" width="5" height="1"/>
      <rect fill="var(--ember-hover)" x="59" y="17" width="3" height="1"/>
      <rect fill="var(--ember-hover)" x="58" y="18" width="5" height="1"/>
      <rect fill="var(--ember-hover)" x="58" y="19" width="5" height="1"/>
      <rect fill="var(--ember-hover)" x="58" y="20" width="5" height="1"/>
      <rect fill="var(--ember-hover)" x="58" y="21" width="5" height="1"/>
      <rect fill="var(--ember-hover)" x="59" y="22" width="3" height="1"/>
      <rect fill="var(--ember-bright)" x="60" y="19" width="1" height="1"/>
      <rect fill="var(--ember-bright)" x="59" y="20" width="3" height="1"/>
      <rect fill="var(--ember-bright)" x="59" y="21" width="3" height="1"/>
