    <rect fill="var(--fg-subtle)" x="54" y="27" width="12" height="6"/>
    <rect fill="var(--fg-faint)"  x="56" y="29" width="8"  height="1"/>
    <rect fill="var(--fg-muted)"  x="53" y="33" width="14" height="1"/>
    <rect fill="var(--fg-subtle)" x="52" y="34" width="16" height="2"/>
