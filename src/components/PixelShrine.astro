      <rect fill="var(--fg-subtle)" x="89" y="9"  width="7"  height="26"/>
      <rect fill="var(--fg-faint)"  x="90" y="9"  width="1"  height="26"/>
      <rect fill="var(--fg-faint)"  x="92" y="9"  width="1"  height="26"/>
      <rect fill="var(--fg-faint)"  x="94" y="9"  width="1"  height="26"/>
      <rect fill="var(--fg-subtle)" x="88" y="35" width="9"  height="1"/>
      <rect fill="var(--fg-muted)"  x="87" y="36" width="11" height="2"/>
    </g>
