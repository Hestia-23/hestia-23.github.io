      <rect fill="var(--accent-hover)" x="104" y="10" width="1" height="1"/>
      <rect fill="var(--accent-hover)" x="103" y="11" width="2" height="1"/>
      <rect fill="var(--accent-hover)" x="104" y="12" width="1" height="1"/>
      <rect fill="var(--accent-hover)" x="104" y="13" width="2" height="1"/>
      <rect fill="var(--accent-hover)" x="105" y="14" width="1" height="1"/>
      <rect fill="var(--accent-hover)" x="105" y="15" width="1" height="1"/>
    </g>
    <rect class="cloud-hit" fill="transparent" x="99" y="5" width="12" height="6"/>
  </g>

  <g class="pillar pillar-left">
    <g class="pillar-body">
      <rect fill="var(--fg-muted)"  x="23" y="6"  width="11" height="2"/>
      <rect fill="var(--fg-subtle)" x="24" y="8"  width="9"  height="1"/>
