      <rect fill="var(--ember-wash)" x="59" y="14" width="1" height="1"/>
      <rect fill="var(--ember-wash)" x="61" y="14" width="1" height="1"/>
      <rect fill="var(--ember-wash)" x="58" y="15" width="1" height="1"/>
      <rect fill="var(--ember-wash)" x="62" y="15" width="1" height="1"/>
      <rect fill="var(--ember-wash)" x="64" y="15" width="1" height="1"/>
