    <rect fill="var(--ember)" x="12" y="8" width="1" height="1"/>
    <rect fill="var(--ember)" x="10" y="9" width="3" height="1"/>
    <rect fill="var(--ember)" x="11" y="5"  width="1" height="2"/>
    <rect fill="var(--ember)" x="11" y="10" width="1" height="2"/>
    <rect fill="var(--ember)" x="8"  y="8"  width="2" height="1"/>
    <rect fill="var(--ember)" x="13" y="8"  width="2" height="1"/>
    <rect fill="var(--ember)" x="9"  y="6"  width="1" height="1"/>
    <rect fill="var(--ember)" x="8"  y="5"  width="1" height="1"/>
    <rect fill="var(--ember)" x="13" y="6"  width="1" height="1"/>
    <rect fill="var(--ember)" x="14" y="5"  width="1" height="1"/>
    <rect fill="var(--ember)" x="9"  y="10" width="1" height="1"/>
    <rect fill="var(--ember)" x="8"  y="11" width="1" height="1"/>
    <rect fill="var(--ember)" x="13" y="10" width="1" height="1"/>
