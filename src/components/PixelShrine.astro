    </g>
  </g>

  <g>
    <rect class="smoke s1" fill="var(--fg-muted)" x="60" y="22" width="1" height="1"/>
    <rect class="smoke s2" fill="var(--fg-muted)" x="59" y="21" width="1" height="1"/>
    <rect class="smoke s3" fill="var(--fg-muted)" x="61" y="22" width="1" height="1"/>
  </g>

  <rect class="flame-hit" fill="transparent" x="55" y="13" width="11" height="13"/>

  <rect fill="var(--rule-strong)" x="0" y="38" width="120" height="1"/>
  <rect fill="var(--rule)"        x="0" y="39" width="120" height="1"/>
</svg>

<script>
  const STATES = ['is-lit', 'is-dim', 'is-out'] as const;
  const STAR_TWINKLE_MS = 800;
  const CLOUD_PUFF_MS  = 600;
  const PILLAR_RUMBLE_MS = 750;

  const pulse = (el: Element | null, cls: string, ms: number) => {
    if (!el) return;
    el.classList.remove(cls);
    void (el as HTMLElement).getBoundingClientRect();
    el.classList.add(cls);
    window.setTimeout(() => el.classList.remove(cls), ms);
  };

  document.querySelectorAll<SVGElement>('.shrine').forEach((shrine) => {
    let idx = 0;

    const cycleFlame = () => {
      shrine.classList.remove(...STATES);
      idx = (idx + 1) % STATES.length;
      shrine.classList.add(STATES[idx]);
    };

    shrine.querySelector('.flame-hit')?.addEventListener('click', cycleFlame);

    const star = shrine.querySelector('.star');
    shrine.querySelector('.star-hit')?.addEventListener('click', () => {
      pulse(star, 'is-twinkling', STAR_TWINKLE_MS);
    });

    const cloud = shrine.querySelector('.cloud');
    shrine.querySelector('.cloud-hit')?.addEventListener('click', () => {
      pulse(cloud, 'is-puffed', CLOUD_PUFF_MS);
    });

    shrine.querySelectorAll<SVGElement>('.pillar').forEach((pillar) => {
      pillar.querySelector('.pillar-hit')?.addEventListener('click', () => {
        pulse(pillar, 'is-rumbling', PILLAR_RUMBLE_MS);
      });
    });

  });
</script>
