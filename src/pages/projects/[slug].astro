---
import Layout from '../../layouts/Layout.astro';
import Section from '../../components/Section.astro';
import BackLink from '../../components/BackLink.astro';
import X from '../../components/icons/brand/X.astro';
import Reddit from '../../components/icons/brand/Reddit.astro';
import YouTube from '../../components/icons/brand/YouTube.astro';
import Go from '../../components/icons/brand/Go.astro';
import Wails from '../../components/icons/brand/Wails.astro';
import Html5 from '../../components/icons/brand/Html5.astro';
import Css from '../../components/icons/brand/Css.astro';
import JavaScript from '../../components/icons/brand/JavaScript.astro';
import TypeScript from '../../components/icons/brand/TypeScript.astro';
import React from '../../components/icons/brand/React.astro';
import TailwindCSS from '../../components/icons/brand/TailwindCSS.astro';
import RadixUI from '../../components/icons/brand/RadixUI.astro';
import MobX from '../../components/icons/brand/MobX.astro';
import Lucide from '../../components/icons/brand/Lucide.astro';
import Vite from '../../components/icons/brand/Vite.astro';
import AstroIcon from '../../components/icons/brand/Astro.astro';
import AlpineJs from '../../components/icons/brand/AlpineJs.astro';
import Htmx from '../../components/icons/brand/Htmx.astro';
import Kotlin from '../../components/icons/brand/Kotlin.astro';
import Rust from '../../components/icons/brand/Rust.astro';
import VanillaCss from '../../components/icons/brand/VanillaCss.astro';
import { PROJECTS, type Project } from '../../data/projects';

export function getStaticPaths() {
  return PROJECTS.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;

const STACK_ICONS: Record<string, any> = {
  'Go': Go,
  'Wails': Wails,
  'HTML': Html5,
  'CSS': Css,
  'JavaScript': JavaScript,
  'TypeScript': TypeScript,
  'React': React,
  'Tailwind CSS': TailwindCSS,
  'Radix UI': RadixUI,
  'MobX': MobX,
  'Lucide': Lucide,
  'Vite': Vite,
  'Astro': AstroIcon,
  'Alpine.js': AlpineJs,
  'htmx': Htmx,
  'Kotlin': Kotlin,
  'Rust': Rust,
  'Vanilla CSS': VanillaCss,
};
---

<Layout title={`Hestia · ${project.title}`}>
  <Section eyebrow={`§ ${project.date}`} title={project.title}>
    <BackLink href="/projects/" />

    <dl class="project-spec">
      <div class="project-spec-row">
        <dt>Stack</dt>
        <dd>
          <div class="project-stack">
            {project.stack.map((name) => {
              const Icon = STACK_ICONS[name];
              return Icon ? (
                <span class="project-stack-icon" data-tooltip={name} role="img" aria-label={name}>
                  <Icon />
                </span>
              ) : (
                <span class="project-stack-text">{name}</span>
              );
            })}
          </div>
        </dd>
      </div>
      {project.status && (
        <div class="project-spec-row">
          <dt>Status</dt>
          <dd>{project.status}</dd>
        </div>
      )}
      <div class="project-spec-row">
        <dt>Date</dt>
        <dd>{project.date}</dd>
      </div>
      {project.url && (
        <div class="project-spec-row">
          <dt>Site</dt>
          <dd><a href={project.url}>{project.url.replace(/^https?:\/\//, '').replace(/\/$/, '')}</a></dd>
        </div>
      )}
      {project.repoUrl && (
        <div class="project-spec-row">
          <dt>Source</dt>
          <dd><a href={project.repoUrl}>{project.repoUrl.replace(/^https?:\/\/(www\.)?/, '')}</a></dd>
        </div>
      )}
      {project.socials && (
        <div class="project-spec-row">
          <dt>Socials</dt>
          <dd>
            <div class="project-socials">
              {project.socials.x && (
                <a class="project-social" href={project.socials.x} aria-label="X"><X /></a>
              )}
              {project.socials.reddit && (
                <a class="project-social" href={project.socials.reddit} aria-label="Reddit"><Reddit /></a>
              )}
              {project.socials.youtube && (
                <a class="project-social" href={project.socials.youtube} aria-label="YouTube"><YouTube /></a>
              )}
            </div>
          </dd>
        </div>
      )}
    </dl>

    <div class="prose">
      {project.subtitle && <p class="project-detail-subtitle"><em>{project.subtitle}.</em></p>}
      {project.body.map((para) => <p>{para}</p>)}
    </div>

    {(project.url || project.repoUrl) && (
      <div class="detail-ctas">
        {project.url && <a class="btn btn-primary" href={project.url}>Visit site</a>}
        {project.repoUrl && <a class="btn btn-ghost" href={project.repoUrl}>View repo</a>}
      </div>
    )}
  </Section>
</Layout>
