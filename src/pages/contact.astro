---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import ContactList from '../components/ContactList.astro';
import ContactIcon from '../components/icons/Contact.astro';
import { CONTACT } from '../data/contact';
---

<Layout title="Alethia · Contact">
  <Section title="One address, read weekly." icon={ContactIcon}>
    <div class="prose contact-prose">
      <p>Email for business inquiries only. Mention me on X (formerly Twitter) for quick replies.</p>
    </div>
    <ContactList items={CONTACT} />
  </Section>
</Layout>

<style>
  .contact-prose {
    margin-bottom: var(--space-7);
  }
</style>
